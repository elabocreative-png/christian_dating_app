rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isMatchParticipant(matchData) {
      return signedIn()
        && matchData != null
        && request.auth.uid in matchData.users;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);

      match /blocked/{blockedUserId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /likes/{likeId} {
      // Signed-in users can read likes they sent or received (supports list queries).
      allow read: if signedIn() && (
        resource == null ||
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );

      allow create: if signedIn() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.fromUserId != request.resource.data.toUserId;

      allow update: if false;

      allow delete: if signedIn() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
    }

    match /issue_reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0;
      allow read, update, delete: if false;
    }

    match /matches/{matchId} {
      // Split get/list so existence checks work; list must mirror array-contains queries.
      allow get: if signedIn() && (
        resource == null || request.auth.uid in resource.data.users
      );

      allow list: if signedIn() && request.auth.uid in resource.data.users;

      allow create: if signedIn() &&
        request.resource.data.users is list &&
        request.resource.data.users.size() == 2 &&
        request.auth.uid in request.resource.data.users;

      allow update: if signedIn() &&
        isMatchParticipant(resource.data) &&
        isMatchParticipant(request.resource.data);

      allow delete: if signedIn() && isMatchParticipant(resource.data);

      match /messages/{messageId} {
        function parentMatch() {
          return get(/databases/$(database)/documents/matches/$(matchId)).data;
        }

        allow read: if signedIn() &&
          request.auth.uid in parentMatch().users;

        allow create: if signedIn() &&
          request.auth.uid in parentMatch().users &&
          request.resource.data.senderId == request.auth.uid;

        allow update: if signedIn() &&
          request.auth.uid in parentMatch().users &&
          resource.data.senderId != request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']);

        allow delete: if signedIn() &&
          request.auth.uid in parentMatch().users;
      }
    }
  }
}
